

<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
<div class="auth-links">
  <% if user_signed_in? %>
    <% if current_page?(root_path) %> 
      <% if current_user.image_url.present? %>
      
      <%= image_tag(current_user.image_url, alt: "Profile Image", width: 50, height: 50, class: 'profile-image') if current_user.image_url.present? %>
      <% end %>
      <p class="welcome-message">Welcome, <%= current_user.name %>!</p>
      <%= link_to 'Logout', destroy_user_session_path, data: { turbo_method: :delete }, class: 'logout-button' %>
    <% end %> 
  <% end %>
</div>





    <%= yield %>
   






  </body>
</html>
